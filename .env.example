# FlinkPilot — 环境变量示例
# 复制此文件为 .env 并填入真实值
# 注意：.env 已加入 .gitignore，不要提交真实密钥

# ─────────────────────────────────────────────
# LLM 配置
# ─────────────────────────────────────────────
# 推荐：OpenRouter（无地区限制，支持 DeepSeek/Claude/GPT）
LLM_API_KEY=sk-or-xxxx
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=deepseek/deepseek-chat

# ─────────────────────────────────────────────
# PostgreSQL（与 docker-compose.yml 对应）
# ─────────────────────────────────────────────
POSTGRES_PASSWORD=change-me-in-production
# 从 backend 容器内访问，主机名使用 Docker 服务名 "db"
DATABASE_URL=postgresql://postgres:change-me-in-production@db:5432/flinkpilot
# 从宿主机（本地开发）访问，使用 localhost
DATABASE_URL_LOCAL=postgresql://postgres:change-me-in-production@localhost:5432/flinkpilot

# ─────────────────────────────────────────────
# Flink 服务地址（Docker 容器内互相访问，使用服务名）
# ─────────────────────────────────────────────
FLINK_REST_URL=http://flink-jobmanager:8081
FLINK_SQL_GATEWAY_URL=http://flink-sql-gateway:8083
